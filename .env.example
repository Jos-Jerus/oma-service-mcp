# OMA Service MCP Server Configuration
# Copy this file to .env and adjust values as needed.

# --- MCP Server ---
# MCP_HOST=0.0.0.0
# MCP_PORT=8000
# TRANSPORT=streamable-http  # Options: streamable-http (for lightspeed-stack), sse

# --- Migration Planner API ---
MIGRATION_PLANNER_URL=http://localhost:7443

# --- Authentication ---
# AUTH_TYPE: none | forwarded
#
# - none:      No auth header sent to migration-planner (local dev)
# - forwarded: Forward Authorization header from lightspeed-stack (production)
#              lightspeed-stack resolves auth from secret files, kubernetes tokens,
#              or client-provided tokens (via MCP-HEADERS) and sends it as a
#              standard Authorization: Bearer header to this MCP server.
AUTH_TYPE=none

# --- Logging ---
# LOGGING_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_TO_FILE=true    # Set to false in containers
